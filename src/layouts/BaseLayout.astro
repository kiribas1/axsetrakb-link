---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Espanol',
  zh: '中文',
  ru: 'Русский',
  pt: 'Portugues',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Google Fonts - Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #333;
        background: #fafafa;
      }
      a {
        color: #d63384;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
        color: #a020f0;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }

      /* HEADER */
      header {
        background: #fff;
        padding: 14px 0;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 3px solid transparent;
        border-image: linear-gradient(90deg, #f472b6, #a855f7, #fb923c) 1;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      }
      header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .logo {
        font-size: 1.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #ec4899, #a855f7, #f97316);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.02em;
      }
      .logo:hover {
        text-decoration: none;
        opacity: 0.85;
      }
      nav {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      nav a {
        color: #555;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 500;
        transition: all 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #fff;
        background: linear-gradient(135deg, #ec4899, #a855f7);
        text-decoration: none;
      }

      /* MAIN */
      main {
        min-height: 70vh;
        padding: 40px 0;
      }

      /* FOOTER */
      footer {
        background: #f3f4f6;
        color: #888;
        padding: 28px 0;
        text-align: center;
        font-size: 0.85rem;
        border-top: 2px solid #f0e6ff;
      }
      footer a {
        color: #a855f7;
      }

      /* AD SLOT */
      .ad-slot {
        background: linear-gradient(135deg, #fef3f8, #f5f0ff);
        border: 1px dashed #e8cff0;
        padding: 20px;
        text-align: center;
        margin: 28px 0;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c4a0d0;
        font-size: 0.8rem;
        border-radius: 12px;
      }

      /* HERO */
      .hero {
        text-align: center;
        padding: 70px 24px;
        background: linear-gradient(135deg, #ec4899 0%, #a855f7 40%, #f97316 100%);
        color: white;
        border-radius: 20px;
        margin-bottom: 8px;
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 20% 50%, rgba(255,255,255,0.15), transparent 50%),
          radial-gradient(circle at 80% 30%, rgba(255,255,255,0.1), transparent 40%);
        pointer-events: none;
      }
      .hero h1 {
        font-size: 2.8rem;
        margin-bottom: 16px;
        font-weight: 800;
        letter-spacing: -0.02em;
        position: relative;
        color: #fff;
        text-shadow: 0 2px 4px rgba(0,0,0,.15);
      }
      .hero p {
        font-size: 1.15rem;
        opacity: 1;
        color: #fff;
        text-shadow: 0 1px 3px rgba(0,0,0,.2);
        max-width: 600px;
        margin: 0 auto;
        position: relative;
        font-weight: 400;
      }

      @media (max-width: 640px) {
        .hero h1 {
          font-size: 1.8rem;
        }
        .hero {
          padding: 50px 18px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href={`/${lang}/`}><slot name="logo">axsetrakb</slot></a>
        <nav>
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={loc === lang ? 'active' : ''}>
                {langNames[loc]}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} <slot name="footer-name">axsetrakb</slot>. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
